<%- include('../partials/header') %>

<div class="form-container">
    <h2>Edit Train</h2>
    <form action="/train/<%= train._id %>?_method=PUT" method="POST">
        <div class="form-group">
            <label>Train Name (Read Only)</label>
            <input type="text" value="<%= train.trainName %>" style="background-color: #eee;" readonly>
        </div>
        <div class="form-group">
            <label>Time</label>
            <input type="text" name="train[time]" value="<%= train.time %>" required>
        </div>
        <div class="form-group">
            <label>Seats Left</label>
            <input type="number" name="train[seatsLeft]" value="<%= train.seatsLeft %>">
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Save Changes</button>
    </form>
    <div style="margin-top: 15px; text-align: center;">
        <a href="/train/<%= train._id %>">Back to Details</a>
    </div>
</div>

<%- include('../partials/footer') %>
