<%- include('../partials/header') %>

<div class="form-container">
    <h2>Add New Train</h2>
    <form action="/train" method="POST">
        <div class="form-group">
            <label>Train Name</label>
            <input type="text" name="train[trainName]" placeholder="Enter Train Name" required>
        </div>
        <div class="form-group">
            <label>Time</label>
            <input type="text" name="train[time]" placeholder="e.g. 10:30 AM" required>
        </div>
        <div class="form-group">
            <label>Seats Left</label>
            <input type="number" name="train[seatsLeft]">
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Add Train</button>
    </form>
    <div style="margin-top: 15px; text-align: center;">
        <a href="/train">Back to List</a>
    </div>
</div>

<%- include('../partials/footer') %>
